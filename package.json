{
	"name": "Fylo",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^5",
			"convex": "^1.32.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "vitest run --config ./vitest.workspace.ts",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @Fylo/backend dev",
		"dev:setup": "turbo -F @Fylo/backend dev:setup"
	},
	"dependencies": {
		"@Fylo/env": "workspace:*",
		"dotenv": "catalog:",
		"framer-motion": "^12.35.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@Fylo/config": "workspace:*",
		"@playwright/test": "^1.58.2",
		"jsdom": "^26.1.0",
		"playwright": "^1.58.2",
		"turbo": "^2.8.12",
		"typescript": "catalog:",
		"vitest": "^4.0.18"
	},
	"packageManager": "bun@1.3.9"
}
